# ============================================
# STAGE 1: Build React Application
# ============================================
FROM node:18-alpine AS builder

WORKDIR /app

# Copier les fichiers de configuration npm
COPY package*.json ./

# Installer les dépendances
RUN npm install

# Copier les fichiers de configuration TypeScript/Vite
COPY tsconfig*.json ./
COPY vite.config.ts ./
COPY index.html ./

# Copier le code source
COPY src/ ./src/
COPY public/ ./public/

# Copier le SDK si présent (optionnel)
COPY sdk/ ./sdk/ 2>/dev/null || true

# Build de production avec variables d'environnement
ENV NODE_ENV=production
ENV VITE_APP_NAME=Claraverse
ENV VITE_BACKEND_URL=https://pybackend.zeabur.app

RUN npm run build

# ============================================
# STAGE 2: Production avec Nginx
# ============================================
FROM nginx:alpine

# Copier les fichiers buildés depuis le stage builder
COPY --from=builder /app/dist /usr/share/nginx/html

# Configuration Nginx optimisée pour React SPA
RUN echo 'server {\n\
    listen 80;\n\
    server_name _;\n\
    root /usr/share/nginx/html;\n\
    index index.html;\n\
\n\
    # Compression gzip\n\
    gzip on;\n\
    gzip_vary on;\n\
    gzip_min_length 1024;\n\
    gzip_types text/plain text/css text/xml text/javascript application/javascript application/json application/xml+rss image/svg+xml;\n\
\n\
    # Headers de sécurité\n\
    add_header X-Frame-Options "SAMEORIGIN" always;\n\
    add_header X-Content-Type-Options "nosniff" always;\n\
    add_header X-XSS-Protection "1; mode=block" always;\n\
\n\
    # Servir les fichiers statiques avec cache long terme\n\
    location ~* \\.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$ {\n\
        expires 1y;\n\
        add_header Cache-Control "public, immutable";\n\
        try_files $uri =404;\n\
    }\n\
\n\
    # React Router - IMPORTANT: toujours renvoyer index.html\n\
    location / {\n\
        try_files $uri $uri/ /index.html;\n\
        add_header Cache-Control "no-cache";\n\
    }\n\
\n\
    # Health check endpoint\n\
    location /health {\n\
        access_log off;\n\
        return 200 "healthy\\n";\n\
        add_header Content-Type text/plain;\n\
    }\n\
}\n' > /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
